# ── Project Stripes — Environment Variables ──
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Formspree (Contact Form) ──
# 1. Create a free account at https://formspree.io
# 2. Create a new form → copy the Form ID (e.g. xabcdefg)
# 3. Paste it here
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_form_id

# ── Site URL ──
# Used for canonical URLs and OG metadata
NEXT_PUBLIC_SITE_URL=https://www.projectstripes.xyz

# ── V2: Supabase (not needed for V1) ──
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── V2: Razorpay (not needed for V1) ──
# NEXT_PUBLIC_RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# ── V2: Resend (transactional email, not needed for V1) ──
# RESEND_API_KEY=
